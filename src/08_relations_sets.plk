P136 chess_attack_relation () => R0[:1.1]
list_new() => Z1[:L32.0]
pair(4[:32.0], 5[:32.0]) => Z2[:P32.0]
list_push(Z1[:L32.0], Z2[:P32.0]) => Z1[:L32.0]
pair_list_count_first(Z1[:L32.0], 4[:32.0]) => Z3[:32.0]
(0[:32.0] < Z3[:32.0]) => R0[:1.1]
END

P137 logic_not_session () => R0[:1.1]
